# ─── Data loading ─────────────────────────────────────────────────────────────

def load_excel(path: str) -> pd.DataFrame:
    """Load all worksheets, stack them, and return a clean DataFrame."""
    xl = pd.ExcelFile(path)
    frames = []
    for sheet in xl.sheet_names:
        df = xl.parse(sheet)
        # Normalise column names: strip whitespace, lower-case for matching
        df.columns = df.columns.str.strip()
        # Case-insensitive rename to canonical names
        col_map = {c: c for c in df.columns}
        for canon in list(REQUIRED_COLS):
            for raw in df.columns:
                if raw.lower() == canon.lower() and raw != canon:
                    col_map[raw] = canon
        df = df.rename(columns=col_map)
        missing = REQUIRED_COLS - set(df.columns)
        if missing:
            print(f"  [skip] Sheet '{sheet}' missing columns: {missing}")
            continue
        df["_sheet"] = sheet
        frames.append(df[list(REQUIRED_COLS) + ["_sheet"]])

    if not frames:
        sys.exit("ERROR: No usable worksheets found. Check column names.")

    out = pd.concat(frames, ignore_index=True)
    out["date"] = pd.to_datetime(out["date"], errors="coerce")
    out = out.dropna(subset=["date", "Deal"])
    out["Deal"] = out["Deal"].astype(str).str.strip()
    for c in ["collat_bal", "1mo_dlq90_reported", "3mo_cpr_reported", "3mo_cdr_reported"]:
        out[c] = pd.to_numeric(out[c], errors="coerce")
    out = out.sort_values(["Deal", "date"])
    return out


# ─── Plotly figure builder ────────────────────────────────────────────────────

def build_figure(df_deal: pd.DataFrame, deal_name: str) -> go.Figure:
    """Build a 2×2 subplot figure for one deal."""
    fig = make_subplots(
        rows=2, cols=2,
        subplot_titles=[c["label"] for c in CHART_DEFS],
        vertical_spacing=0.14,
        horizontal_spacing=0.10,
    )
    positions = [(1, 1), (1, 2), (2, 1), (2, 2)]

    for cd, (row, col) in zip(CHART_DEFS, positions):
        series = df_deal[cd["col"]].copy()
        dates  = df_deal["date"]

        # Latest value for annotation
        latest = series.dropna().iloc[-1] if not series.dropna().empty else None

        # Area trace
        fig.add_trace(
            go.Scatter(
                x=dates, y=series,
                mode="lines",
                name=cd["label"],
                line=dict(color=cd["color"], width=2.5, shape="spline", smoothing=0.4),
                fill="tozeroy",
                fillcolor=cd["fill"],
                hovertemplate=f"<b>%{{x|%b %Y}}</b><br>{cd['label']}: %{{y:{cd['fmt']}}}{cd['unit']}<extra></extra>",
            ),
            row=row, col=col,
        )

        # Dot for latest value
        if latest is not None:
            fig.add_trace(
                go.Scatter(
                    x=[dates.iloc[-1]], y=[latest],
                    mode="markers",
                    marker=dict(color=cd["color"], size=9, line=dict(color="#0b0f1a", width=2)),
                    showlegend=False,
                    hoverinfo="skip",
                ),
                row=row, col=col,
            )

        # Axis formatting
        axis_kwargs = dict(
            showgrid=True, gridcolor=PALETTE["grid"], gridwidth=1,
            zeroline=False,
            tickfont=dict(color=PALETTE["text_dim"], size=10, family="'DM Mono', monospace"),
            linecolor=PALETTE["border"],
        )
        y_suffix = cd["unit"] if cd["unit"] in ("%",) else ""
        y_fmt    = ".1f" if cd["unit"] == "%" else ",.3s"

        fig.update_xaxes(
            **axis_kwargs,
            tickformat="%b %Y",
            row=row, col=col,
        )
        fig.update_yaxes(
            **axis_kwargs,
            ticksuffix=y_suffix,
            tickformat=y_fmt,
            row=row, col=col,
        )

    # Subplot title colour
    for ann in fig.layout.annotations:
        ann.update(font=dict(color=PALETTE["text"], size=13, family="'Syne', sans-serif"),
                   x=ann.x, y=ann.y)

    fig.update_layout(
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        showlegend=False,
        margin=dict(l=40, r=20, t=55, b=30),
        font=dict(family="'DM Mono', monospace", color=PALETTE["text"]),
        hoverlabel=dict(
            bgcolor=PALETTE["surface2"],
            font_color=PALETTE["text"],
            bordercolor=PALETTE["border"],
        ),
    )
    return fig


# ─── Per-deal stats helper ────────────────────────────────────────────────────

def stats_for_deal(df_deal: pd.DataFrame) -> dict:
    stats = {}
    for cd in CHART_DEFS:
        s = df_deal[cd["col"]].dropna()
        stats[cd["col"]] = {
            "latest": s.iloc[-1]  if len(s) else None,
            "min":    s.min()     if len(s) else None,
            "max":    s.max()     if len(s) else None,
            "mean":   s.mean()    if len(s) else None,
        }
    return stats


def fmt_val(v, cd):
    if v is None:
        return "—"
    if cd["unit"] == "%":
        return f"{v:{cd['fmt']}}{cd['unit']}"
    return f"{v:{cd['fmt']}}"


