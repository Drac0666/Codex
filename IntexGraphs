<script>
const ALL_DEALS   = {deals_json};
const ALL_FIGURES = {figures_json};
const ALL_STATS   = {stats_json};
const CHART_DEFS  = {chart_defs_json};

let currentDeal = null;

function buildSidebar(deals) {{
  const list = document.getElementById('deal-list');
  list.innerHTML = '';
  deals.forEach(d => {{
    const btn = document.createElement('button');
    btn.className = 'deal-btn' + (d === currentDeal ? ' active' : '');
    btn.textContent = d;
    btn.dataset.deal = d;
    btn.onclick = () => selectDeal(d);
    list.appendChild(btn);
  }});
  document.getElementById('deal-count').textContent =
    deals.length + ' deal' + (deals.length !== 1 ? 's' : '');
}}

function filterDeals(q) {{
  buildSidebar(ALL_DEALS.filter(d => d.toLowerCase().includes(q.toLowerCase())));
}}

function fmtVal(v, cd) {{
  if (v === null || v === undefined) return '-';
  if (cd.unit === '%') return v.toFixed(2) + '%';
  return new Intl.NumberFormat('en-US', {{notation:'compact', maximumFractionDigits:1}}).format(v);
}}

function selectDeal(deal) {{
  currentDeal = deal;
  document.querySelectorAll('.deal-btn').forEach(b =>
    b.classList.toggle('active', b.dataset.deal === deal));

  document.getElementById('empty-state').style.display = 'none';
  document.getElementById('dash-view').style.display   = 'flex';
  document.getElementById('deal-title').textContent = deal;

  const fig  = ALL_FIGURES[deal];
  const obs  = fig ? fig.data[0].x.length : 0;
  document.getElementById('deal-obs').textContent = obs + ' obs';

  const stats       = ALL_STATS[deal] || {{}};
  const hasQuarterly = CHART_DEFS.some(cd => (stats[cd.col] || {{}}).frequency === 'quarterly');
  document.getElementById('q-badge').style.display = hasQuarterly ? 'inline-block' : 'none';

  // KPI cards
  const strip = document.getElementById('kpi-strip');
  strip.innerHTML = '';
  CHART_DEFS.forEach((cd, i) => {{
    const s   = stats[cd.col] || {{}};
    const isQ = s.frequency === 'quarterly';
    strip.innerHTML += `
      <div class="kpi c${{i+1}}${{isQ ? ' is-quarterly' : ''}}">
        <div class="kpi-icon">${{cd.icon}}</div>
        <div class="kpi-label">${{cd.label}}</div>
        <div class="kpi-value">${{fmtVal(s.latest, cd)}}</div>
        <div class="kpi-range">min ${{fmtVal(s.min, cd)}} / max ${{fmtVal(s.max, cd)}}</div>
        ${{isQ ? '<span class="kpi-freq-tag">quarterly</span>' : ''}}
      </div>`;
  }});

  // Plot
  if (fig) {{
    Plotly.newPlot('plot', fig.data, fig.layout, {{
      responsive: true,
      displayModeBar: true,
      displaylogo: false,
      modeBarButtonsToRemove: ['select2d','lasso2d','autoScale2d'],
      toImageButtonOptions: {{format:'svg', filename: deal + '_dashboard'}},
    }});
  }}
}}

buildSidebar(ALL_DEALS);
