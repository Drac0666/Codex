# ─── Column resolution ────────────────────────────────────────────────────────

def resolve_columns(raw_cols):
    """
    Given the raw column names of a sheet, return:
      (mapping_dict, missing_list)
    where mapping_dict = { canonical_key: raw_column_name }.
    Matching is case-insensitive and strips surrounding whitespace.
    """
    normed = {c.strip().lower(): c for c in raw_cols}
    mapping = {}
    missing = []

    for key, aliases in COLUMN_ALIASES.items():
        found = None
        for alias in aliases:
            if alias.strip().lower() in normed:
                found = normed[alias.strip().lower()]
                break
        if found:
            mapping[key] = found
        else:
            missing.append(key)

    return mapping, missing


# ─── Frequency detection ──────────────────────────────────────────────────────

def detect_frequency(dates, values):
    """
    Return 'quarterly', 'monthly', or 'unknown' by inspecting the median gap
    between consecutive non-null observations.

      quarterly -> median gap > 60 days  (every ~3 months)
      monthly   -> median gap <= 60 days
    """
    valid_dates = dates[values.notna()].sort_values().reset_index(drop=True)
    if len(valid_dates) < 3:
        return "unknown"
    diffs = valid_dates.diff().dropna().dt.days
    return "quarterly" if diffs.median() > 60 else "monthly"


# ─── Data loading ─────────────────────────────────────────────────────────────

def load_excel(path):
    """Load all worksheets, resolve columns via alias table, stack and return clean DataFrame."""
    xl = pd.ExcelFile(path)
    frames = []

    for sheet in xl.sheet_names:
        raw = xl.parse(sheet)
        raw.columns = raw.columns.astype(str)

        col_map, missing = resolve_columns(list(raw.columns))

        if missing:
            print(f"  [skip] Sheet '{sheet}' - could not resolve: {missing}")
            continue

        # Rename matched raw columns to canonical keys
        rename = {v: k for k, v in col_map.items()}
        df = raw.rename(columns=rename)[CANONICAL_COLS].copy()
        df["_sheet"] = sheet
        frames.append(df)
        print(f"  [ok]   Sheet '{sheet}' resolved: "
              f"dlq90<-'{col_map['dlq90']}', "
              f"cpr<-'{col_map['cpr']}', "
              f"cdr<-'{col_map['cdr']}'")

    if not frames:
        sys.exit(
            "ERROR: No usable worksheets found.\n"
            "Check the COLUMN_ALIASES table at the top of this script."
        )

    out = pd.concat(frames, ignore_index=True)
    out["date"] = pd.to_datetime(out["date"], errors="coerce")
    out["deal"] = out["deal"].astype(str).str.strip()
    out = out.dropna(subset=["date", "deal"])

    for c in ["collat_bal", "dlq90", "cpr", "cdr"]:
        out[c] = pd.to_numeric(out[c], errors="coerce")

    return out.sort_values(["deal", "date"]).reset_index(drop=True)


# ─── Trace builders ───────────────────────────────────────────────────────────

def _monthly_traces(dates, series, cd):
    """Smooth filled area traces for dense / monthly series."""
    traces = [
        go.Scatter(
            x=dates, y=series,
            mode="lines",
            name=cd["label"],
            line=dict(color=cd["color"], width=2.5, shape="spline", smoothing=0.4),
            fill="tozeroy",
            fillcolor=cd["fill"],
            connectgaps=False,
            hovertemplate=(
                f"<b>%{{x|%b %Y}}</b><br>{cd['label']}: "
                f"%{{y:{cd['fmt']}}}{cd['unit']}<extra></extra>"
            ),
        )
    ]
    valid = series.dropna()
    if not valid.empty:
        last_idx = valid.index[-1]
        traces.append(go.Scatter(
            x=[dates.loc[last_idx]], y=[valid.iloc[-1]],
            mode="markers",
            marker=dict(color=cd["color"], size=9,
                        line=dict(color="#0b0f1a", width=2)),
            showlegend=False, hoverinfo="skip",
        ))
    return traces


def _quarterly_traces(dates, series, cd):
    """
    Bar chart for quarterly / sparse series.
    Only plots rows where a value is actually reported -
    no NaN gaps, no misleading interpolation between periods.
    """
    mask   = series.notna()
    x_vals = dates[mask]
    y_vals = series[mask]

    return [
        go.Bar(
            x=x_vals, y=y_vals,
            name=cd["label"],
            marker_color=cd["color"],
            marker_opacity=0.75,
            marker_line=dict(color=cd["color"], width=1),
            hovertemplate=(
                f"<b>%{{x|%b %Y}}</b><br>{cd['label']}: "
                f"%{{y:{cd['fmt']}}}{cd['unit']}<extra></extra>"
            ),
        )
    ]


# ─── Figure builder ───────────────────────────────────────────────────────────

def build_figure(df_deal, deal_name):
    """Build 2x2 subplot figure, auto-detecting quarterly vs monthly per metric."""
    positions = [(1, 1), (1, 2), (2, 1), (2, 2)]

    # Pre-detect frequencies to build subplot titles
    frequencies = {}
    subplot_titles = []
    for cd in CHART_DEFS:
        freq = detect_frequency(df_deal["date"], df_deal[cd["col"]])
        frequencies[cd["col"]] = freq
        title = cd["label"] + (" [Q]" if freq == "quarterly" else "")
        subplot_titles.append(title)

    fig = make_subplots(
        rows=2, cols=2,
        subplot_titles=subplot_titles,
        vertical_spacing=0.15,
        horizontal_spacing=0.10,
    )

    for cd, (row, col) in zip(CHART_DEFS, positions):
        series = df_deal[cd["col"]].copy()
        dates  = df_deal["date"].copy()
        freq   = frequencies[cd["col"]]

        traces = (_quarterly_traces if freq == "quarterly"
                  else _monthly_traces)(dates, series, cd)

        for tr in traces:
            fig.add_trace(tr, row=row, col=col)

        axis_base = dict(
            showgrid=True, gridcolor=PALETTE["grid"], gridwidth=1,
            zeroline=False,
            tickfont=dict(color=PALETTE["text_dim"], size=10,
                          family="'DM Mono', monospace"),
            linecolor=PALETTE["border"],
        )
        y_suffix = cd["unit"] if cd["unit"] == "%" else ""
        y_fmt    = ".1f" if cd["unit"] == "%" else ",.3s"

        fig.update_xaxes(**axis_base, tickformat="%b %Y", row=row, col=col)
        fig.update_yaxes(**axis_base, ticksuffix=y_suffix,
                         tickformat=y_fmt, row=row, col=col)

    # Colour [Q] titles differently to make it obvious
    for ann in fig.layout.annotations:
        is_q = "[Q]" in (ann.text or "")
        ann.update(font=dict(
            color=PALETTE["accent3"] if is_q else PALETTE["text"],
            size=12,
            family="'Syne', sans-serif",
        ))

    fig.update_layout(
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        showlegend=False,
        barmode="overlay",
        margin=dict(l=40, r=20, t=55, b=30),
        font=dict(family="'DM Mono', monospace", color=PALETTE["text"]),
        hoverlabel=dict(
            bgcolor=PALETTE["surface2"],
            font_color=PALETTE["text"],
            bordercolor=PALETTE["border"],
        ),
    )
    return fig


# ─── Stats helper ─────────────────────────────────────────────────────────────

def stats_for_deal(df_deal):
    result = {}
    for cd in CHART_DEFS:
        s    = df_deal[cd["col"]].dropna()
        freq = detect_frequency(df_deal["date"], df_deal[cd["col"]])
        result[cd["col"]] = {
            "latest":    float(s.iloc[-1]) if len(s) else None,
            "min":       float(s.min())    if len(s) else None,
            "max":       float(s.max())    if len(s) else None,
            "mean":      float(s.mean())   if len(s) else None,
            "frequency": freq,
        }
    return result


