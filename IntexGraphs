#!/usr/bin/env python3
"""
Deal Performance Dashboard Generator
Reads an Excel file with deal performance data and generates an interactive HTML dashboard.

Set INPUT_FILE and OUTPUT_FILE below, then run all cells.
"""

# ─── Configuration ────────────────────────────────────────────────────────────
INPUT_FILE  = "your_file.xlsx"      # <- path to your Excel file
OUTPUT_FILE = "dashboard.html"      # <- where to save the HTML dashboard
# ──────────────────────────────────────────────────────────────────────────────

import sys
import json
import pandas as pd
import numpy as np
import plotly.graph_objects as go
from plotly.subplots import make_subplots
import plotly.io as pio
from pathlib import Path


# ─── Column alias table ───────────────────────────────────────────────────────
# KEY         -> internal name used everywhere in the script
# VALUE LIST  -> all acceptable raw column names (case-insensitive, order = priority)

COLUMN_ALIASES: dict = {
    # -- identifiers ----------------------------------------------------------
    "deal":       ["Deal", "deal", "deal_name", "DealName"],
    "date":       ["date", "Date", "report_date", "period", "Period"],

    # -- balance --------------------------------------------------------------
    "collat_bal": ["collat_bal", "collateral_balance", "coll_bal",
                   "collateral_bal", "bal", "balance"],

    # -- DLQ 90+ --------------------------------------------------------------
    "dlq90":      ["1mo_dlq90_reported", "1m_dlq90_reported",
                   "1mo_dq90_reported",  "1m_dq90_reported",
                   "dlq90_reported",     "dq90_reported",
                   "dlq90",              "dq90"],

    # -- CPR ------------------------------------------------------------------
    "cpr":        ["3mo_cpr_reported", "3m_cpr_reported",
                   "cpr_reported",     "cpr"],

    # -- CDR ------------------------------------------------------------------
    "cdr":        ["3mo_cdr_reported", "3m_cdr_reported",
                   "cdr_reported",     "cdr"],
}

# Internal column order used after alias resolution
CANONICAL_COLS = ["deal", "date", "collat_bal", "dlq90", "cpr", "cdr"]


