"""


# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Deal Performance Dashboard Generator")
    parser.add_argument("--input",  required=True, help="Path to Excel file (.xlsx)")
    parser.add_argument("--output", default="dashboard.html", help="Output HTML file (default: dashboard.html)")
    args = parser.parse_args()

    print(f"📂  Reading: {args.input}")
    df = load_excel(args.input)

    deals = sorted(df["Deal"].unique().tolist())
    print(f"✅  Found {len(deals)} deal(s): {deals[:5]}{'…' if len(deals) > 5 else ''}")

    figures_dict = {}
    stats_dict   = {}

    for deal in deals:
        df_d = df[df["Deal"] == deal].copy()
        fig  = build_figure(df_d, deal)
        figures_dict[deal] = json.loads(pio.to_json(fig))
        stats_dict[deal]   = stats_for_deal(df_d)

    # Serialise chart def metadata for JS
    chart_defs_js = [
        {"col": cd["col"], "label": cd["label"], "unit": cd["unit"], "icon": cd["icon"]}
        for cd in CHART_DEFS
    ]

    html = HTML_TEMPLATE.format(
        **PALETTE,
        deals_json      = json.dumps(deals),
        figures_json    = json.dumps(figures_dict),
        stats_json      = json.dumps(stats_dict),
        chart_defs_json = json.dumps(chart_defs_js),
    )

    out_path = Path(args.output)
    out_path.write_text(html, encoding="utf-8")
    print(f"🎉  Dashboard saved → {out_path.resolve()}")
    print(f"    Open in any modern browser. No server required.")


if __name__ == "__main__":
    main()
