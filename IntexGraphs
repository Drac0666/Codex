#!/usr/bin/env python3
"""
Deal Performance Dashboard Generator
Reads an Excel file with deal performance data and generates an interactive HTML dashboard.

Usage:
    python generate_dashboard.py --input your_file.xlsx --output dashboard.html

Required columns (per worksheet):
    Deal, date, collat_bal, 1mo_dlq90_reported, 3mo_cpr_reported, 3mo_cdr_reported
"""

