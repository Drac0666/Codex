def load_excel_data(input_file):
    print(f"Reading file: {input_file}")

    input_path = Path(input_file)

    if not input_path.exists():
        raise FileNotFoundError(f"Input file does not exist: {input_path.resolve()}")

    sheets = pd.read_excel(input_path, sheet_name=None)

    loaded_frames = []

    for sheet_name, raw_df in sheets.items():
        sheet_df = raw_df.copy()
        sheet_df.columns = [str(c) for c in sheet_df.columns]

        resolved, missing = resolve_columns(sheet_df.columns, COLUMN_ALIASES)

        if missing:
            print(f"[skip] Sheet '{sheet_name}' missing keys: {missing}")
            continue

        selected_raw_columns = [resolved[c] for c in CANONICAL_COLUMNS]

        out = sheet_df.loc[:, selected_raw_columns].copy()
        out.columns = CANONICAL_COLUMNS
        out["_sheet"] = str(sheet_name)

        loaded_frames.append(out)

        print(
            f"[ok] Sheet '{sheet_name}' | "
            f"deal='{resolved['deal']}', "
            f"date='{resolved['date']}', "
            f"collat_bal='{resolved['collat_bal']}', "
            f"dlq90='{resolved['dlq90']}', "
            f"cpr='{resolved['cpr']}', "
            f"cdr='{resolved['cdr']}'"
        )

    if not loaded_frames:
        raise ValueError(
            "No sheets were loaded. Every sheet was skipped because required columns "
            "could not be resolved."
        )

    all_df = pd.concat(loaded_frames, ignore_index=True)

    all_df["date"] = pd.to_datetime(all_df["date"], errors="coerce")

    all_df["deal"] = (
        all_df["deal"]
        .astype(str)
        .str.strip()
    )

    for col in ["collat_bal", "dlq90", "cpr", "cdr"]:
        all_df[col] = pd.to_numeric(all_df[col], errors="coerce")

    before_rows = len(all_df)

    all_df = all_df.dropna(subset=["date", "deal"])
    all_df = all_df[all_df["deal"].str.len() > 0]
    all_df = all_df[all_df["deal"].str.lower() != "nan"]

    after_rows = len(all_df)

    if after_rows == 0:
        raise ValueError(
            "Data was loaded, but all rows were removed after cleaning. "
            "Most likely the resolved date column could not be parsed as dates, "
            "or the deal column is blank."
        )

    all_df = all_df.sort_values(["deal", "date"]).reset_index(drop=True)

    print(f"Rows before cleaning: {before_rows:,}")
    print(f"Rows after cleaning: {after_rows:,}")
    print(f"Total deals loaded: {all_df['deal'].nunique():,}")

    return all_df


# ============================================================
# Frequency detection
# ============================================================

def detect_frequency(dates, values):
    """
    Extract dates where values are non-null, sort, compute day gaps.

    Returns:
      - quarterly if median gap > 60 days
      - monthly if median gap <= 60 days
      - unknown if fewer than 3 non-null points
    """
    temp = pd.DataFrame(
        {
            "date": dates,
            "value": values,
        }
    )

    temp = temp.dropna(subset=["date", "value"]).sort_values("date")

    if len(temp) < 3:
        return "unknown"

    gaps = temp["date"].diff().dt.days.dropna()

    if gaps.empty:
        return "unknown"

    median_gap = gaps.median()

    if median_gap > 60:
        return "quarterly"

    return "monthly"


# ============================================================
# Weighted index
# ============================================================

def build_index(df):
    required = ["deal", "date", "collat_bal", "dlq90", "cpr", "cdr"]

    missing = [c for c in required if c not in df.columns]

    if missing:
        raise KeyError(
            f"Cannot build index. Missing columns: {missing}. "
            f"Available columns: {list(df.columns)}"
        )

    output_columns = ["deal", "date", "collat_bal", "dlq90", "cpr", "cdr", "_sheet"]

    source_deal_count = int(df["deal"].dropna().nunique())
    all_dates = sorted(pd.Series(df["date"].dropna().unique()).tolist())

    rows = []

    coverage = {
        "dlq90": [],
        "cpr": [],
        "cdr": [],
    }

    for dt in all_dates:
        day = df[df["date"] == dt]

        row = {
            "deal": INDEX_DEAL_NAME,
            "date": dt,
            "collat_bal": day["collat_bal"].dropna().sum(),
            "dlq90": np.nan,
            "cpr": np.nan,
            "cdr": np.nan,
            "_sheet": "INDEX",
        }

        for metric in ["dlq90", "cpr", "cdr"]:
            valid = day.dropna(subset=[metric, "collat_bal"]).copy()
            valid = valid[valid["collat_bal"] != 0]

            if valid.empty or valid["collat_bal"].sum() == 0:
                row[metric] = np.nan
                coverage[metric].append(0)
            else:
                row[metric] = (
                    valid[metric].mul(valid["collat_bal"]).sum()
                    / valid["collat_bal"].sum()
                )
                coverage[metric].append(int(valid["deal"].nunique()))

        rows.append(row)

    index_df = pd.DataFrame(rows, columns=output_columns)

    print("Index build summary:")
    print(f"  Source deals: {source_deal_count:,}")
    print(f"  Date points: {len(index_df):,}")

    for metric in ["dlq90", "cpr", "cdr"]:
        counts = pd.Series(coverage[metric], dtype="float64")

        if counts.empty:
            print(f"  {metric}: avg=0.00, min=0, max=0 deals per period")
        else:
            print(
                f"  {metric}: "
                f"avg={counts.mean():.2f}, "
                f"min={counts.min():.0f}, "
                f"max={counts.max():.0f} deals per period"
            )

    if index_df.empty:
        raise ValueError(
            "Index could not be built because there are no valid date points."
        )

    return index_df


