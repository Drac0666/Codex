def stats_for_deal(deal_df):
    stats = {
        "_meta": {
            "n_obs": int(len(deal_df)),
            "start_date": None,
            "end_date": None,
        }
    }

    if not deal_df.empty:
        stats["_meta"]["start_date"] = pd.Timestamp(deal_df["date"].min()).isoformat()
        stats["_meta"]["end_date"] = pd.Timestamp(deal_df["date"].max()).isoformat()

    for metric, cfg in METRICS.items():
        if metric == "collat_bal":
            frequency = "monthly"
        else:
            frequency = detect_frequency(deal_df["date"], deal_df[metric])

        non_null = deal_df[metric].dropna()

        if non_null.empty:
            latest_value = None
            min_value = None
            max_value = None
        else:
            latest_idx = deal_df[metric].last_valid_index()
            latest_value = float(deal_df.loc[latest_idx, metric])
            min_value = float(non_null.min())
            max_value = float(non_null.max())

        stats[metric] = {
            "label": cfg["label"],
            "unit": cfg["unit"],
            "icon": cfg["icon"],
            "color": cfg["color"],
            "is_percent": bool(cfg["is_percent"]),
            "frequency": frequency,
            "latest": latest_value,
            "min": min_value,
            "max": max_value,
        }

    return stats


