            hovertemplate="%{x|%b %Y}<br>%{y:,.2f}<extra></extra>",
        ),
        row=row,
        col=col,
    )

    non_null = deal_df.dropna(subset=[metric])

    if not non_null.empty:
        last = non_null.iloc[-1]

        fig.add_trace(
            go.Scatter(
                x=[last["date"]],
