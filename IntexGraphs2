# ============================================================
# Utility functions
# ============================================================

def normalize_col_name(value):
    return str(value).strip().lower()


def resolve_columns(columns, aliases):
    """
    Resolve raw worksheet columns to canonical names.

    Matching is:
      - case-insensitive
      - whitespace-stripped
      - first matching alias wins
    """
    normalized_to_raw = {}

    for raw_col in columns:
        normalized = normalize_col_name(raw_col)

        if normalized not in normalized_to_raw:
            normalized_to_raw[normalized] = raw_col

    resolved = {}
    missing = []

    for canonical, alias_list in aliases.items():
        matched_raw_col = None

        for alias in alias_list:
            normalized_alias = normalize_col_name(alias)

            if normalized_alias in normalized_to_raw:
                matched_raw_col = normalized_to_raw[normalized_alias]
                break

        if matched_raw_col is None:
            missing.append(canonical)
        else:
            resolved[canonical] = matched_raw_col

    return resolved, missing


def hex_to_rgba(hex_color, alpha):
    hex_value = hex_color.strip().lstrip("#")

    red = int(hex_value[0:2], 16)
    green = int(hex_value[2:4], 16)
    blue = int(hex_value[4:6], 16)

    return f"rgba({red},{green},{blue},{alpha})"


def replace_nonfinite(obj):
    """
    Recursively replace NaN / Infinity with None after PlotlyJSONEncoder
    converts pandas / numpy / timestamps.
    """
    if isinstance(obj, dict):
        return {str(k): replace_nonfinite(v) for k, v in obj.items()}

    if isinstance(obj, list):
        return [replace_nonfinite(v) for v in obj]

    if isinstance(obj, float):
        if math.isnan(obj) or math.isinf(obj):
            return None

    return obj


def make_dashboard_payload(all_deals, all_figures, all_stats):
    """
    Convert dashboard data to strict JSON and Base64-encode it.

    This avoids fragile JavaScript injection issues caused by:
      - braces in Python f-strings
      - quote escaping
      - NaN / Infinity
      - pandas timestamps
      - numpy arrays
      - accidental </script> sequences
    """
    payload = {
        "deals": all_deals,
        "figures": all_figures,
        "stats": all_stats,
        "indexDealName": INDEX_DEAL_NAME,
    }

    raw_json = json.dumps(
        payload,
        cls=PlotlyJSONEncoder,
        ensure_ascii=False,
        allow_nan=True,
    )

    parsed = json.loads(raw_json)
    parsed = replace_nonfinite(parsed)

    clean_json = json.dumps(
        parsed,
        ensure_ascii=False,
        allow_nan=False,
        separators=(",", ":"),
    )

    return base64.b64encode(clean_json.encode("utf-8")).decode("ascii")


