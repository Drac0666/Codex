def stats_for_deal(deal_df):
    stats = {
        "_meta": {
            "n_obs": int(len(deal_df)),
            "start_date": deal_df["date"].min().isoformat() if len(deal_df) else None,
            "end_date": deal_df["date"].max().isoformat() if len(deal_df) else None,
        }
    }

    for metric, cfg in METRICS.items():
        values = deal_df[metric]

        if metric == "collat_bal":
            frequency = "monthly"
        else:
            frequency = detect_frequency(deal_df["date"], values)

        non_null = values.dropna()

        if non_null.empty:
            latest_value = None
            min_value = None
            max_value = None
        else:
            latest_idx = values.last_valid_index()
            latest_value = float(values.loc[latest_idx])
            min_value = float(non_null.min())
            max_value = float(non_null.max())

        stats[metric] = {
            "label": cfg["label"],
            "unit": cfg["unit"],
            "icon": cfg["icon"],
            "color": cfg["color"],
            "is_percent": cfg["is_percent"],
            "frequency": frequency,
            "latest": latest_value,
            "min": min_value,
            "max": max_value,
        }

    return stats


