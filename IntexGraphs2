def load_excel_data(input_file):
    print(f"Reading file: {input_file}")

    sheets = pd.read_excel(input_file, sheet_name=None)
    loaded = []

    for sheet_name, sheet_df in sheets.items():
        df = sheet_df.copy()
        df.columns = [str(c) for c in df.columns]

        resolved, missing = resolve_columns(df.columns, COLUMN_ALIASES)

        if missing:
            print(f"[skip] Sheet '{sheet_name}' missing keys: {missing}")
            continue

        selected_raw_columns = [resolved[c] for c in CANONICAL_COLUMNS]
        out = df.loc[:, selected_raw_columns].copy()
        out.columns = CANONICAL_COLUMNS
        out["_sheet"] = sheet_name

        loaded.append(out)

        print(
            f"[ok] Sheet '{sheet_name}' | "
            f"dlq90='{resolved['dlq90']}', "
            f"cpr='{resolved['cpr']}', "
            f"cdr='{resolved['cdr']}'"
        )

    if not loaded:
        raise ValueError("No sheets were successfully loaded. Check required columns and aliases.")

    all_df = pd.concat(loaded, ignore_index=True)

    all_df["date"] = pd.to_datetime(all_df["date"], errors="coerce")
    all_df["deal"] = all_df["deal"].astype(str).str.strip()

    for col in ["collat_bal", "dlq90", "cpr", "cdr"]:
        all_df[col] = pd.to_numeric(all_df[col], errors="coerce")

    all_df = all_df.dropna(subset=["date", "deal"])
    all_df = all_df[all_df["deal"].str.len() > 0]
    all_df = all_df.sort_values(["deal", "date"]).reset_index(drop=True)

    print(f"Total deals loaded: {all_df['deal'].nunique()}")

    return all_df


# ============================================================
# Frequency detection
# ============================================================

def detect_frequency(dates, values):
    """
    Detect monthly vs quarterly metric frequency.

    Uses only dates where the metric value is non-null.
    Returns:
      - "quarterly" if median gap > 60 days
      - "monthly" if median gap <= 60 days
      - "unknown" if fewer than 3 non-null points
    """
    temp = pd.DataFrame({"date": dates, "value": values})
    temp = temp.dropna(subset=["date", "value"]).sort_values("date")

    if len(temp) < 3:
        return "unknown"

    gaps = temp["date"].diff().dt.days.dropna()

    if gaps.empty:
        return "unknown"

    median_gap = gaps.median()

    if median_gap > 60:
        return "quarterly"

    return "monthly"


