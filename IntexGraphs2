def add_monthly_area_trace(fig, deal_df, metric, cfg):
    color = cfg["color"]

    fig.add_trace(
        go.Scatter(
            x=deal_df["date"],
            y=deal_df[metric],
            mode="lines",
            name=cfg["label"],
            line={
                "color": color,
                "width": 2.4,
                "shape": "spline",
                "smoothing": 0.4,
            },
            fill="tozeroy",
            fillcolor=hex_to_rgba(color, 0.18),
            connectgaps=False,
            hovertemplate="%{x|%b %Y}<br>%{y:,.2f}<extra></extra>",
            meta={
                "comparison": False,
            },
        ),
        row=cfg["row"],
        col=cfg["col"],
    )

    non_null = deal_df.dropna(subset=[metric])

    if not non_null.empty:
        last = non_null.iloc[-1]

        fig.add_trace(
            go.Scatter(
                x=[last["date"]],
                y=[last[metric]],
                mode="markers",
                name=f"{cfg['label']} latest",
                marker={
                    "color": color,
                    "size": 8,
                    "line": {
                        "color": "#e2e8f0",
                        "width": 1,
                    },
                },
                showlegend=False,
                hovertemplate="Latest<br>%{x|%b %Y}<br>%{y:,.2f}<extra></extra>",
                meta={
                    "comparison": False,
                },
            ),
            row=cfg["row"],
            col=cfg["col"],
        )


def add_quarterly_bar_trace(fig, deal_df, metric, cfg):
    color = cfg["color"]
    q_df = deal_df.dropna(subset=[metric])

    fig.add_trace(
        go.Bar(
            x=q_df["date"],
            y=q_df[metric],
            name=cfg["label"],
            marker={
                "color": hex_to_rgba(color, 0.72),
                "line": {
                    "color": color,
                    "width": 1,
                },
            },
            hovertemplate="%{x|%b %Y}<br>%{y:,.2f}<extra></extra>",
            meta={
                "comparison": False,
            },
        ),
        row=cfg["row"],
        col=cfg["col"],
    )


def add_index_comparison_traces(fig, index_df):
    """
    Add hidden index comparison traces for DLQ90, CPR, and CDR only.
    These are toggled on/off in JavaScript.
    Collateral balance is intentionally excluded.
    """
    if index_df is None or index_df.empty:
        return

    comparison_metrics = ["dlq90", "cpr", "cdr"]

    for metric in comparison_metrics:
        cfg = METRICS[metric]

        metric_df = index_df.dropna(subset=[metric]).copy()

        if metric_df.empty:
            continue

        fig.add_trace(
            go.Scatter(
                x=metric_df["date"],
                y=metric_df[metric],
                mode="lines+markers",
                name=f"Index {cfg['label']}",
                line={
                    "color": "#a78bfa",
                    "width": 2,
                    "dash": "dot",
                },
                marker={
                    "color": "#a78bfa",
                    "size": 5,
                    "symbol": "circle-open",
                },
                visible=False,
                showlegend=False,
                connectgaps=False,
                hovertemplate=(
                    f"Index {cfg['label']}<br>"
                    "%{x|%b %Y}<br>"
                    "%{y:,.2f}<extra></extra>"
                ),
                meta={
                    "comparison": True,
                    "metric": metric,
                },
            ),
            row=cfg["row"],
            col=cfg["col"],
        )


def build_figure(deal_df, index_df=None, include_index_comparison=False):
    deal_df = deal_df.sort_values("date").reset_index(drop=True)

    stats = stats_for_deal(deal_df)

    subplot_titles = []

    for metric, cfg in METRICS.items():
        title = cfg["label"]

        if stats[metric]["frequency"] == "quarterly":
            title += " [Q]"

        subplot_titles.append(title)

    fig = make_subplots(
        rows=2,
        cols=2,
        subplot_titles=subplot_titles,
        vertical_spacing=0.14,
        horizontal_spacing=0.09,
    )

    # Invisible trace so JS can use fig.data[0].x.length for observation count.
    fig.add_trace(
        go.Scatter(
            x=deal_df["date"],
            y=[0] * len(deal_df),
            mode="markers",
            marker={
                "size": 0,
                "opacity": 0,
            },
            line={
                "width": 0,
            },
            opacity=0,
            showlegend=False,
            hoverinfo="skip",
            name="_observation_count",
            meta={
                "comparison": False,
            },
        ),
        row=1,
        col=1,
    )

    for metric, cfg in METRICS.items():
        frequency = stats[metric]["frequency"]

        if metric == "collat_bal":
            add_monthly_area_trace(fig, deal_df, metric, cfg)
        elif frequency == "quarterly":
            add_quarterly_bar_trace(fig, deal_df, metric, cfg)
        else:
            add_monthly_area_trace(fig, deal_df, metric, cfg)

    if include_index_comparison:
        add_index_comparison_traces(fig, index_df)

    grid_color = "#1e2d3d"

    for row in [1, 2]:
        for col in [1, 2]:
            fig.update_xaxes(
                row=row,
                col=col,
                showgrid=True,
                gridcolor=grid_color,
                zeroline=False,
                tickformat="%b %Y",
                tickfont={
                    "family": "DM Mono, monospace",
                    "size": 10,
                    "color": "#64748b",
                },
                linecolor="#1f2d45",
            )

            fig.update_yaxes(
                row=row,
                col=col,
                showgrid=True,
                gridcolor=grid_color,
                zeroline=False,
                tickfont={
                    "family": "DM Mono, monospace",
                    "size": 10,
                    "color": "#64748b",
                },
                linecolor="#1f2d45",
            )

    for metric, cfg in METRICS.items():
        if cfg["is_percent"]:
            fig.update_yaxes(
                row=cfg["row"],
                col=cfg["col"],
                ticksuffix="%",
                tickformat=".1f",
            )
        else:
            fig.update_yaxes(
                row=cfg["row"],
                col=cfg["col"],
                tickformat=",.3s",
            )

    for idx, annotation in enumerate(fig.layout.annotations):
        metric = list(METRICS.keys())[idx]
        is_quarterly = stats[metric]["frequency"] == "quarterly"

        annotation.font = {
            "family": "Syne, sans-serif",
            "size": 14,
            "color": "#f87171" if is_quarterly else "#e2e8f0",
        }

    fig.update_layout(
        autosize=True,
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
        margin={
            "l": 48,
            "r": 24,
            "t": 54,
            "b": 42,
        },
        showlegend=False,
        font={
            "family": "DM Mono, monospace",
            "color": "#e2e8f0",
        },
        hoverlabel={
            "bgcolor": "#1a2235",
            "bordercolor": "#1f2d45",
            "font": {
                "family": "DM Mono, monospace",
                "color": "#e2e8f0",
            },
        },
        bargap=0.25,
    )

    return fig.to_plotly_json(), stats


