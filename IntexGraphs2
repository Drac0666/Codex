      buildSidebar(ALL_DEALS);
    }

    function renderKpis(deal) {
      const stats = ALL_STATS[deal];
      const container = document.getElementById("kpis");

      const order = ["dlq90", "cpr", "cdr", "collat_bal"];

      container.innerHTML = order.map(metric => {
        const s = stats[metric];
        const isQuarterly = s.frequency === "quarterly";

        const latest = formatMetric(s.latest, s.is_percent);
        const minValue = formatMetric(s.min, s.is_percent);
        const maxValue = formatMetric(s.max, s.is_percent);

        const qTag = isQuarterly ? '<span class="q-tag">Q</span>' : "";

        return [
          '<div class="kpi-card ' + (isQuarterly ? "quarterly" : "") + '">',
            '<div class="kpi-head">',
              '<div>',
                '<span class="kpi-icon" style="color:' + escapeHtml(s.color) + '">' + escapeHtml(s.icon) + '</span> ',
                '<span class="kpi-label">' + escapeHtml(s.label) + '</span>',
                qTag,
              '</div>',
            '</div>',
            '<div class="kpi-value">' + escapeHtml(latest) + '</div>',
            '<div class="kpi-range">min ' + escapeHtml(minValue) + ' / max ' + escapeHtml(maxValue) + '</div>',
          '</div>'
        ].join("");
      }).join("");
    }

    function toggleIndexComparison(show) {
      if (!activeDeal || activeDeal === INDEX_DEAL_NAME) {
        return;
      }

      const plot = document.getElementById("plot");

      if (!plot || !plot.data) {
        return;
      }

      const comparisonTraceIndexes = [];

      plot.data.forEach((trace, idx) => {
        if (trace.meta && trace.meta.comparison === true) {
          comparisonTraceIndexes.push(idx);
        }
      });

      if (comparisonTraceIndexes.length === 0) {
        return;
      }

      Plotly.restyle(
        plot,
        {
          visible: show
        },
        comparisonTraceIndexes
      );
    }

    function selectDeal(deal) {
      activeDeal = deal;
      buildSidebar(ALL_DEALS);

      const fig = ALL_FIGURES[deal];
      const stats = ALL_STATS[deal];

      if (!fig || !stats) {
