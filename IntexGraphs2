  <script>
    const ALL_DEALS = __ALL_DEALS__;
    const ALL_FIGURES = __ALL_FIGURES__;
    const ALL_STATS = __ALL_STATS__;
    const INDEX_DEAL_NAME = "★ INDEX";

    let activeDeal = null;
    let currentFilter = "";

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function compactNumber(value) {
      if (value === null || value === undefined || Number.isNaN(value)) {
        return "—";
      }

      const abs = Math.abs(value);

      if (abs >= 1_000_000_000) {
        return (value / 1_000_000_000).toFixed(2) + "B";
      }

      if (abs >= 1_000_000) {
        return (value / 1_000_000).toFixed(2) + "M";
      }

      if (abs >= 1_000) {
        return (value / 1_000).toFixed(2) + "K";
      }

      return value.toLocaleString(undefined, {
        maximumFractionDigits: 2
      });
    }

    function formatMetric(value, isPercent) {
      if (value === null || value === undefined || Number.isNaN(value)) {
        return "—";
      }

      if (isPercent) {
        return value.toFixed(1) + "%";
      }

      return compactNumber(value);
    }

    function buildSidebar(deals) {
      const indexButton = document.getElementById("indexButton");
      const list = document.getElementById("dealList");
      const dealCount = document.getElementById("dealCount");

      const individualDeals = deals.filter(d => d !== INDEX_DEAL_NAME);
      const q = currentFilter.trim().toLowerCase();

      const filteredDeals = individualDeals.filter(d =>
        d.toLowerCase().includes(q)
      );

      indexButton.textContent = INDEX_DEAL_NAME;
      indexButton.title = INDEX_DEAL_NAME;
      indexButton.onclick = () => selectDeal(INDEX_DEAL_NAME);
      indexButton.classList.toggle("active", activeDeal === INDEX_DEAL_NAME);

      dealCount.textContent =
        individualDeals.length.toLocaleString() +
        " individual deal" +
        (individualDeals.length === 1 ? "" : "s");

      list.innerHTML = "";

      filteredDeals.forEach(deal => {
        const btn = document.createElement("button");
        btn.className = "deal-btn";
        btn.textContent = deal;
        btn.title = deal;
        btn.onclick = () => selectDeal(deal);

        if (deal === activeDeal) {
          btn.classList.add("active");
        }

        list.appendChild(btn);
      });
    }

    function filterDeals(q) {
      currentFilter = q || "";
      buildSidebar(ALL_DEALS);
    }

    function renderKpis(deal) {
      const stats = ALL_STATS[deal];
      const container = document.getElementById("kpis");

      const order = ["dlq90", "cpr", "cdr", "collat_bal"];

      container.innerHTML = order.map(metric => {
        const s = stats[metric];
        const isQuarterly = s.frequency === "quarterly";

        const latest = formatMetric(s.latest, s.is_percent);
        const minValue = formatMetric(s.min, s.is_percent);
        const maxValue = formatMetric(s.max, s.is_percent);

        const qTag = isQuarterly ? `<span class="q-tag">Q</span>` : "";

        return `
          <div class="kpi-card ${isQuarterly ? "quarterly" : ""}">
            <div class="kpi-head">
              <div>
                <span class="kpi-icon" style="color:${s.color}">${escapeHtml(s.icon)}</span>
                <span class="kpi-label">${escapeHtml(s.label)}</span>
                ${qTag}
              </div>
            </div>
            <div class="kpi-value">${escapeHtml(latest)}</div>
            <div class="kpi-range">min ${escapeHtml(minValue)} / max ${escapeHtml(maxValue)}</div>
          </div>
        `;
      }).join("");
    }

    function selectDeal(deal) {
      activeDeal = deal;
      buildSidebar(ALL_DEALS);

      const fig = ALL_FIGURES[deal];
      const stats = ALL_STATS[deal];

      document.getElementById("emptyState").style.display = "none";
      document.getElementById("dashboard").style.display = "flex";

      document.getElementById("dealTitle").textContent = deal;

      const observationCount = fig.data && fig.data.length > 0 && fig.data[0].x
        ? fig.data[0].x.length
        : stats._meta.n_obs;

      document.getElementById("obsCount").textContent =
        observationCount.toLocaleString() + " observations";

      const hasQuarterly = ["dlq90", "cpr", "cdr"].some(
        metric => stats[metric].frequency === "quarterly"
      );

      document.getElementById("quarterlyBadge").style.display =
        hasQuarterly ? "block" : "none";

      renderKpis(deal);

      Plotly.newPlot(
        "plot",
        fig.data,
        fig.layout,
        {
          responsive: true,
          displayModeBar: false
        }
      );
    }

    window.addEventListener("resize", () => {
      const plot = document.getElementById("plot");
      if (plot && activeDeal) {
        Plotly.Plots.resize(plot);
      }
    });

    buildSidebar(ALL_DEALS);
    selectDeal(ALL_DEALS[0]);
  </script>
