# ─── CONFIG ────────────────────────────────────────────────────────────────────
# Each entry is:  ("Canonical Label", ["possible col name 1", "possible col name 2", ...])
# The script scans the header row and uses the FIRST alias it finds.
# A warning is printed if NONE of the aliases are found in a sheet.
# "Current Balance" must always be present — it is the balance denominator.
#
TARGET_COLUMNS = [
    ("Occupancy", [
        "Occupancy",
        "Occupancy (Passthrough)",
        "Occ",
    ]),
    ("Lien Info", [
        "Lien Info",
        "Lien Information",
        "Lien Position",
    ]),
    ("Income Verification for Primary Income", [
        "Income Verification for Primary Income",
        "Income Verification",
        "Income Doc Type",
        "Doc Type",
    ]),
    # ("Property Type", ["Property Type", "Prop Type"]),   # uncomment to include
    # ("Loan Purpose",  ["Loan Purpose",  "Purpose"]),     # uncomment to include
    # ("State",         ["State", "Property State"]),      # uncomment to include
    ("Current Balance", [                                  # ← keep this always
        "Current Balance",
        "Curr Balance",
        "Balance",
    ]),
]

# Derive flat lists used elsewhere
CANONICAL_NAMES   = [c[0] for c in TARGET_COLUMNS]
BALANCE_CANONICAL = "Current Balance"

HEADER_ROW = 11       # row with column names
DATA_START_ROW = 17   # first data row (skip 12-16)

# ─── DRILL-DOWN FILTERS ────────────────────────────────────────────────────────
# Define criteria for rows that should be extracted below each deal summary.
# Each filter is applied to the CATEGORIZED value (after CATEGORY_MAPPINGS).
#
# Supported operators:
#   "not_in"   – include row if value is NOT in the list  (case-insensitive)
#   "in"       – include row if value IS in the list      (case-insensitive)
#   "contains" – include row if value contains the string (case-insensitive)
#   "not_contains" – include row if value does NOT contain the string
#
# Multiple filters are AND-ed together.
# Set DRILL_DOWN_FILTERS = [] to disable the feature entirely.
#
DRILL_DOWN_FILTERS = [
    {
        "column":   "Occupancy",
        "operator": "not_in",
        "values":   ["Prime", "Owner Occupied"],
        "label":    "Occupancy not in [Prime, Owner Occupied]",
    },
    # {
    #     "column":   "Lien Info",
    #     "operator": "not_in",
    #     "values":   ["1st Lien"],
    #     "label":    "Non-first lien positions",
    # },
]

# ─── CATEGORY NORMALIZATION ────────────────────────────────────────────────────
# For each target column, define (keyword_fragment, canonical_label) pairs.
# Matching is case-insensitive. First match wins.
# Values that match nothing are kept exactly as-is (no silent data loss).
#
CATEGORY_MAPPINGS = {
    "Occupancy": [
        ("non-owner",               "Non-Owner Occupied"),
        ("non owner",               "Non-Owner Occupied"),
        ("owner",                   "Owner Occupied"),       # must come AFTER "non-owner"
        ("investment",              "Investment"),
        ("second home",             "Second Home"),
        ("2nd home",                "Second Home"),
        ("unknown",                 "Unknown"),
    ],
    "Lien Info": [
        ("1st",                     "1st Lien"),
        ("first",                   "1st Lien"),
        ("2nd",                     "2nd Lien"),
        ("second",                  "2nd Lien"),
        ("3rd",                     "3rd Lien"),
        ("third",                   "3rd Lien"),
    ],
    "Income Verification for Primary Income": [
        ("full doc",                "Full Doc"),
        ("full",                    "Full Doc"),
        ("bank statement",          "Bank Statement"),
        ("stated",                  "Stated"),
        ("no doc",                  "No Doc"),
        ("nodoc",                   "No Doc"),
        ("asset depletion",         "Asset Depletion"),
        ("asset",                   "Asset Depletion"),
        ("dscr",                    "DSCR"),
        ("unknown",                 "Unknown"),
    ],
}


# ─── HELPERS ───────────────────────────────────────────────────────────────────
def find_columns(header_row_values, sheet_name=""):
    """Return {canonical_name: col_index} by checking each alias list in order."""
    mapping = {}
    for canonical, aliases in TARGET_COLUMNS:
        # exact match first
        for alias in aliases:
            for idx, cell in enumerate(header_row_values):
                if cell is None:
                    continue
                if alias.lower() == str(cell).strip().lower():
                    mapping[canonical] = idx
                    break
            if canonical in mapping:
                break
        # fallback: substring
        if canonical not in mapping:
            for alias in aliases:
                for idx, cell in enumerate(header_row_values):
                    if cell is None:
                        continue
                    cell_str = str(cell).strip()
                    if alias.lower() in cell_str.lower() or cell_str.lower() in alias.lower():
                        mapping[canonical] = idx
                        break
                if canonical in mapping:
                    break
        if canonical not in mapping:
            print(f"  [WARN] '{sheet_name}': none of the aliases for '{canonical}' found → {aliases}")
    return mapping


def find_all_columns(header_row_values):
    """Return all non-None header names with their column indices."""
    result = {}
    for idx, cell in enumerate(header_row_values):
        if cell is not None and str(cell).strip():
            name = str(cell).strip()
            if name not in result:
                result[name] = idx
    return result


def safe_float(val):
    try:
        if val is None or str(val).strip() in ("", "N/A", "n/a", "-"):
            return None
        return float(str(val).replace(",", "").replace("$", "").replace("%", "").strip())
    except (ValueError, TypeError):
        return None


def categorize_value(val, col_name=None):
    if val is None or str(val).strip() in ("", "N/A", "n/a", "-", "nan"):
        return "Missing / Blank"
    raw = str(val).strip()
    if col_name and col_name in CATEGORY_MAPPINGS:
        raw_lower = raw.lower()
        for fragment, canonical in CATEGORY_MAPPINGS[col_name]:
            if fragment.lower() in raw_lower:
                return canonical
    return raw


# ─── FILTER LOGIC ──────────────────────────────────────────────────────────────
def apply_drill_down_filters(df):
    """
    Apply DRILL_DOWN_FILTERS to df (uses categorized values for matching).
    Returns (filtered_df, filter_description_string).
    """
    if not DRILL_DOWN_FILTERS or df is None or df.empty:
        return pd.DataFrame(), ""

    mask = pd.Series([True] * len(df), index=df.index)
    labels = []

    for f in DRILL_DOWN_FILTERS:
        col      = f["column"]
        operator = f["operator"]
        values   = [str(v).lower() for v in f.get("values", [])]
        label    = f.get("label", f"{col} {operator} {f.get('values','')}")

        if col not in df.columns:
            print(f"  [WARN] Drill-down filter column '{col}' not in dataframe – skipping filter.")
            continue

        # Categorize for matching
        categorized = df[col].apply(lambda v: categorize_value(v, col).lower())

        if operator == "not_in":
            mask &= ~categorized.isin(values)
        elif operator == "in":
            mask &= categorized.isin(values)
        elif operator == "contains":
            term = values[0] if values else ""
            mask &= categorized.str.contains(term, na=False)
        elif operator == "not_contains":
            term = values[0] if values else ""
            mask &= ~categorized.str.contains(term, na=False)

        labels.append(label)

    filtered = df[mask].copy()
    return filtered, "  AND  ".join(labels)


# ─── READ DATA ─────────────────────────────────────────────────────────────────
def read_deal_sheet(wb, sheet_name):
    ws = wb[sheet_name]
    rows = list(ws.iter_rows(values_only=True))

    if len(rows) < HEADER_ROW:
        return None, {}, {}

    header_row_values = rows[HEADER_ROW - 1]
    col_map     = find_columns(header_row_values, sheet_name)
    all_col_map = find_all_columns(header_row_values)   # every column in the sheet

    if BALANCE_CANONICAL not in col_map:
        print(f"  [WARN] '{sheet_name}': 'Current Balance' (or alias) not found – skipping.")
        return None, col_map, all_col_map

    data_rows = rows[DATA_START_ROW - 1:]

    # Build records using TARGET columns for summary, but carry ALL columns for drill-down
    records = []
    for row in data_rows:
        if all(v is None for v in row):
            continue
        record = {}
        # target columns under canonical names
        for canon_name, col_idx in col_map.items():
            record[canon_name] = row[col_idx] if col_idx < len(row) else None
        # all other columns under their original header name (for drill-down / stats)
        for col_header, col_idx in all_col_map.items():
            if col_header not in record:
                record[col_header] = row[col_idx] if col_idx < len(row) else None
        records.append(record)

    return pd.DataFrame(records) if records else None, col_map, all_col_map


# ─── ANALYZE ONE CATEGORY ──────────────────────────────────────────────────────
def analyze_column(df, col_name):
    """Return DataFrame with Count, Balance, % of Total Balance per category."""
    if col_name not in df.columns or BALANCE_CANONICAL not in df.columns:
        return pd.DataFrame()

    df2 = df[[col_name, BALANCE_CANONICAL]].copy()
    df2[col_name] = df2[col_name].apply(lambda v: categorize_value(v, col_name))
    df2["_bal"] = df2[BALANCE_CANONICAL].apply(safe_float).fillna(0)

    grouped = (
        df2.groupby(col_name)
        .agg(Count=(col_name, "count"), Balance=("_bal", "sum"))
        .reset_index()
        .rename(columns={col_name: "Category"})
    )
    total_balance = grouped["Balance"].sum()
    grouped["% of Balance"] = grouped["Balance"] / total_balance if total_balance else 0
    grouped["% of Count"]   = grouped["Count"] / grouped["Count"].sum()
    return grouped.sort_values("Balance", ascending=False).reset_index(drop=True)


# ─── STYLES ────────────────────────────────────────────────────────────────────
HEADER_FILL   = PatternFill("solid", start_color="1F4E79")
SUBHDR_FILL   = PatternFill("solid", start_color="2E75B6")
ALT_FILL      = PatternFill("solid", start_color="D6E4F0")
TOTAL_FILL    = PatternFill("solid", start_color="BDD7EE")
FILTER_FILL   = PatternFill("solid", start_color="833C00")   # dark orange – filter header
STATS_FILL    = PatternFill("solid", start_color="375623")   # dark green  – stats header
STATS_S_FILL  = PatternFill("solid", start_color="538135")   # mid green   – stats sub-header
STATS_ALT     = PatternFill("solid", start_color="E2EFDA")   # light green – stats rows

WHITE_FONT  = Font(name="Arial", bold=True, color="FFFFFF", size=10)
BOLD_FONT   = Font(name="Arial", bold=True, size=10)
NORMAL_FONT = Font(name="Arial", size=10)
TOTAL_FONT  = Font(name="Arial", bold=True, size=10)

CENTER = Alignment(horizontal="center", vertical="center", wrap_text=True)
LEFT   = Alignment(horizontal="left",   vertical="center", wrap_text=True)


def thin_border():
    s = Side(style="thin", color="A0A0A0")
    return Border(left=s, right=s, top=s, bottom=s)


# ─── WRITE HELPERS ─────────────────────────────────────────────────────────────
def write_analysis_block(ws, start_row, title, analysis_df, deal_name):
    """Write one category summary block; return next available row."""
    ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=6)
    cell = ws.cell(row=start_row, column=1, value=f"  {deal_name}  –  {title}")
    cell.font = WHITE_FONT; cell.fill = HEADER_FILL; cell.alignment = LEFT
    ws.row_dimensions[start_row].height = 20
    start_row += 1

    headers = ["Category", "Count", "% of Count", "Balance ($)", "% of Balance", ""]
    for c, h in enumerate(headers, 1):
        cell = ws.cell(row=start_row, column=c, value=h)
        cell.font = WHITE_FONT; cell.fill = SUBHDR_FILL
        cell.alignment = CENTER; cell.border = thin_border()
    ws.row_dimensions[start_row].height = 18
    start_row += 1

    if analysis_df.empty:
        ws.cell(row=start_row, column=1, value="No data available").font = NORMAL_FONT
        return start_row + 2

    total_count = analysis_df["Count"].sum()
    total_bal   = analysis_df["Balance"].sum()

    for i, row in analysis_df.iterrows():
        fill = ALT_FILL if i % 2 == 0 else PatternFill("solid", start_color="FFFFFF")
        vals = [row["Category"], row["Count"], row["% of Count"],
                row["Balance"], row["% of Balance"], ""]
        for c, v in enumerate(vals, 1):
            cell = ws.cell(row=start_row, column=c, value=v)
            cell.font = NORMAL_FONT; cell.fill = fill; cell.border = thin_border()
            cell.alignment = LEFT if c == 1 else CENTER
            if c in (3, 5): cell.number_format = "0.0%"
            if c == 4:       cell.number_format = "#,##0.00"
        start_row += 1

    vals = ["TOTAL", total_count, 1.0, total_bal, 1.0, ""]
    for c, v in enumerate(vals, 1):
        cell = ws.cell(row=start_row, column=c, value=v)
        cell.font = TOTAL_FONT; cell.fill = TOTAL_FILL; cell.border = thin_border()
        cell.alignment = LEFT if c == 1 else CENTER
        if c in (3, 5): cell.number_format = "0.0%"
        if c == 4:       cell.number_format = "#,##0.00"
    return start_row + 2


def write_drill_down_section(ws, start_row, filtered_df, filter_label, all_columns):
    """
    Write:
      1. Section header with filter criteria
      2. Statistics table (avg of every numeric column)
      3. Raw source-data rows
    Returns next available row.
    """
    if filtered_df.empty:
        # Still show a header so the user knows the filter ran with 0 results
        ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=len(all_columns) or 6)
        cell = ws.cell(row=start_row, column=1,
                       value=f"  DRILL-DOWN  |  {filter_label}  |  0 rows matched")
        cell.font = WHITE_FONT; cell.fill = FILTER_FILL; cell.alignment = LEFT
        ws.row_dimensions[start_row].height = 20
        return start_row + 2

    n_rows = len(filtered_df)
    # Use only columns that exist in filtered_df
    cols = [c for c in all_columns if c in filtered_df.columns]
    n_cols = max(len(cols), 1)

    # ── Section header ──────────────────────────────────────────────────────
    ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=n_cols)
    cell = ws.cell(row=start_row, column=1,
                   value=f"  DRILL-DOWN  |  {filter_label}  |  {n_rows} rows")
    cell.font = WHITE_FONT; cell.fill = FILTER_FILL; cell.alignment = LEFT
    ws.row_dimensions[start_row].height = 20
    start_row += 1

    # ── Statistics table ────────────────────────────────────────────────────
    # Identify numeric columns
    numeric_cols = []
    averages     = {}
    for col in cols:
        numeric_vals = filtered_df[col].apply(safe_float).dropna()
        if len(numeric_vals) > 0:
            numeric_cols.append(col)
            averages[col] = numeric_vals.mean()

    if numeric_cols:
        # Stats header
        ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=n_cols)
        cell = ws.cell(row=start_row, column=1, value="  STATISTICS  –  Column Averages (numeric columns only)")
        cell.font = WHITE_FONT; cell.fill = STATS_FILL; cell.alignment = LEFT
        ws.row_dimensions[start_row].height = 18
        start_row += 1

        # Stats sub-header row
        for c, col in enumerate(numeric_cols, 1):
            cell = ws.cell(row=start_row, column=c, value=col)
            cell.font = WHITE_FONT; cell.fill = STATS_S_FILL
            cell.alignment = CENTER; cell.border = thin_border()
            ws.column_dimensions[get_column_letter(c)].width = max(
                ws.column_dimensions[get_column_letter(c)].width or 0, len(col) + 4)
        ws.row_dimensions[start_row].height = 32
        start_row += 1

        # Stats average row
        for c, col in enumerate(numeric_cols, 1):
            cell = ws.cell(row=start_row, column=c, value=averages[col])
            cell.font = BOLD_FONT; cell.fill = STATS_ALT
            cell.alignment = CENTER; cell.border = thin_border()
            cell.number_format = "#,##0.00"
        start_row += 2

    # ── Raw data header ─────────────────────────────────────────────────────
    ws.merge_cells(start_row=start_row, start_column=1, end_row=start_row, end_column=n_cols)
    cell = ws.cell(row=start_row, column=1, value="  SOURCE DATA  –  Filtered Rows")
    cell.font = WHITE_FONT; cell.fill = FILTER_FILL; cell.alignment = LEFT
    ws.row_dimensions[start_row].height = 18
    start_row += 1

    # Column headers for raw data
    for c, col in enumerate(cols, 1):
        cell = ws.cell(row=start_row, column=c, value=col)
        cell.font = WHITE_FONT; cell.fill = SUBHDR_FILL
        cell.alignment = CENTER; cell.border = thin_border()
        ws.column_dimensions[get_column_letter(c)].width = max(
            ws.column_dimensions[get_column_letter(c)].width or 0, min(len(col) + 4, 30))
    ws.row_dimensions[start_row].height = 32
    start_row += 1

    # Data rows
    for i, (_, row_data) in enumerate(filtered_df.iterrows()):
        fill = ALT_FILL if i % 2 == 0 else PatternFill("solid", start_color="FFFFFF")
        for c, col in enumerate(cols, 1):
            val = row_data.get(col)
            # Try numeric for known numeric-ish values
            numeric = safe_float(val)
            display_val = numeric if numeric is not None else (
                str(val).strip() if val is not None else "")
            cell = ws.cell(row=start_row, column=c, value=display_val)
            cell.font = NORMAL_FONT; cell.fill = fill; cell.border = thin_border()
            cell.alignment = LEFT
            if numeric is not None:
                cell.number_format = "#,##0.00"
        start_row += 1

    return start_row + 1


def _set_col_widths(ws, widths=None):
    default = [45, 10, 13, 18, 15, 4]
    for i, w in enumerate(widths or default, 1):
        ws.column_dimensions[get_column_letter(i)].width = w


def write_combined_sheet(wb_out, combined_df):
    """Roll-up sheet across ALL deals (summary only, no drill-down)."""
    ws = wb_out.create_sheet("Combined – All Deals")
    row = 1
    for col_name in [c for c in CANONICAL_NAMES if c != BALANCE_CANONICAL]:
        row = write_analysis_block(ws, row, col_name,
                                   analyze_column(combined_df, col_name), "ALL DEALS")
    _set_col_widths(ws)


# ─── MAIN ──────────────────────────────────────────────────────────────────────
INPUT_FILE  = "in.xlsx"
OUTPUT_FILE = "out.xlsx"


def main():
    if not os.path.exists(INPUT_FILE):
        print(f"ERROR: File not found: {INPUT_FILE}")
        sys.exit(1)

    print(f"Reading: {INPUT_FILE}")
    wb_in      = openpyxl.load_workbook(INPUT_FILE, data_only=True)
    sheet_names = wb_in.sheetnames
    print(f"Found {len(sheet_names)} sheet(s): {sheet_names}")

    wb_out = openpyxl.Workbook()
    wb_out.remove(wb_out.active)

    all_dfs = []

    for sheet_name in sheet_names:
        print(f"Processing: {sheet_name}")
        df, col_map, all_col_map = read_deal_sheet(wb_in, sheet_name)
        if df is None or df.empty:
            print(f"  [SKIP] No usable data in '{sheet_name}'.")
            continue

        print(f"  Canonical columns: {list(col_map.keys())}")
        print(f"  Total columns in sheet: {len(all_col_map)}")
        print(f"  Rows: {len(df)}")

        all_dfs.append(df[CANONICAL_NAMES].copy() if all(c in df.columns for c in CANONICAL_NAMES) else df)

        ws  = wb_out.create_sheet(sheet_name[:31])
        row = 1

        # ── Summary tables ──────────────────────────────────────────────────
        for col_name in [c for c in CANONICAL_NAMES if c != BALANCE_CANONICAL]:
            analysis = analyze_column(df, col_name)
            row = write_analysis_block(ws, row, col_name, analysis, sheet_name)

        # ── Drill-down section ──────────────────────────────────────────────
        if DRILL_DOWN_FILTERS:
            filtered_df, filter_label = apply_drill_down_filters(df)
            print(f"  Drill-down rows matched: {len(filtered_df)}")
            # All original column names in sheet order
            ordered_cols = list(all_col_map.keys())
            row = write_drill_down_section(ws, row, filtered_df, filter_label, ordered_cols)

        _set_col_widths(ws)

    if all_dfs:
        combined = pd.concat(all_dfs, ignore_index=True)
        write_combined_sheet(wb_out, combined)
        wb_out.move_sheet("Combined – All Deals", offset=-len(wb_out.sheetnames) + 1)

    wb_out.save(OUTPUT_FILE)
    print(f"\nDone! Summary saved to: {OUTPUT_FILE}")


if __name__ == "__main__":
    main()
